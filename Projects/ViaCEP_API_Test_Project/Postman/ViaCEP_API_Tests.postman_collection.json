          "script": {
            "exec": [
              "pm.test(\"Status code deve ser 200\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "pm.test(\"Resposta deve conter o CEP correto\", function () {\r",
              "    const json = pm.response.json();\r",
              "    pm.expect(json.cep).to.eql(\"01001-000\");\r",
              "});\r",
              "\r",
              "pm.test(\"Resposta deve conter a cidade São Paulo\", function () {\r",
              "    const json = pm.response.json();\r",
              "    pm.expect(json.localidade).to.eql(\"São Paulo\");\r",
              "});\r",
              "\r",
              "pm.test(\"Resposta deve conter a UF SP\", function () {\r",
              "    const json = pm.response.json();\r",
              "    pm.expect(json.uf).to.eql(\"SP\");\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
